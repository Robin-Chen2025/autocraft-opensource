# AutoCraft 环境配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=sqlite:///./tasks.db

# API 配置
API_HOST=0.0.0.0
API_PORT=9001

# OpenClaw Agent 配置（可选）
# OPENCLAW_API_URL=http://localhost:8080
# OPENCLAW_API_KEY=your_api_key_here

# AI 模型配置（可选）
# DEFAULT_MODEL=glm-5
# EXECUTOR_MODEL=deepseek-v3
# VALIDATOR_MODEL=deepseek-thinking